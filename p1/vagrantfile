Vagrant.configure("2") do |config|
  config.vm.box = "debian/bookworm64"
  config.vm.synced_folder ".", "/vagrant", type: "rsync"

  config.vm.define "emmodoglS" do |control|
    control.vm.hostname = "emmodoglS"
    control.vm.network "private_network", ip: "192.168.56.110"
    
    control.vm.provider "libvirt" do |v|
      v.memory = 2048
      v.cpus = 1
    end

    control.vm.provision "shell", path: "scripts/server_setup.sh"
  end

  config.vm.define "eatesSW" do |control|
    control.vm.hostname = "eatesSW"
    control.vm.network "private_network", ip: "192.168.56.111"
    
    control.vm.provider "libvirt" do |v|
      v.memory = 2048
      v.cpus = 1
    end

    control.vm.provision "shell", path: "scripts/worker_setup.sh"
  end
end